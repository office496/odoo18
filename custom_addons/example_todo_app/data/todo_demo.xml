<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Demo Tasks -->
        <record id="demo_task_1" model="todo.task">
            <field name="name">Welcome to Todo App</field>
            <field name="description">This is your first todo task. You can edit, assign, and track progress.</field>
            <field name="assigned_to" ref="base.user_demo"/>
            <field name="category_id" ref="category_work"/>
            <field name="priority">2</field>
            <field name="state">draft</field>
            <field name="tag_ids" eval="[(6, 0, [ref('tag_important')])]"/>
        </record>
        
        <record id="demo_task_2" model="todo.task">
            <field name="name">Complete Project Setup</field>
            <field name="description">Set up the development environment and configure initial settings.</field>
            <field name="assigned_to" ref="base.user_demo"/>
            <field name="category_id" ref="category_project"/>
            <field name="priority">3</field>
            <field name="state">in_progress</field>
            <field name="date_deadline" eval="(DateTime.today() + timedelta(days=2)).strftime('%Y-%m-%d')"/>
            <field name="tag_ids" eval="[(6, 0, [ref('tag_urgent'), ref('tag_important')])]"/>
        </record>
        
        <record id="demo_task_3" model="todo.task">
            <field name="name">Review Documentation</field>
            <field name="description">Review and update project documentation for accuracy.</field>
            <field name="assigned_to" ref="base.user_admin"/>
            <field name="category_id" ref="category_work"/>
            <field name="priority">1</field>
            <field name="state">draft</field>
            <field name="date_deadline" eval="(DateTime.today() + timedelta(days=5)).strftime('%Y-%m-%d')"/>
            <field name="tag_ids" eval="[(6, 0, [ref('tag_follow_up')])]"/>
        </record>
        
        <record id="demo_task_4" model="todo.task">
            <field name="name">Team Meeting Preparation</field>
            <field name="description">Prepare agenda and materials for the weekly team meeting.</field>
            <field name="assigned_to" ref="base.user_demo"/>
            <field name="category_id" ref="category_work"/>
            <field name="priority">2</field>
            <field name="state">done</field>
            <field name="date_deadline" eval="(DateTime.today() - timedelta(days=1)).strftime('%Y-%m-%d')"/>
            <field name="date_completed" eval="(DateTime.today() - timedelta(hours=2)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="tag_ids" eval="[(6, 0, [ref('tag_meeting')])]"/>
        </record>
        
        <record id="demo_task_5" model="todo.task">
            <field name="name">Personal Task Example</field>
            <field name="description">This is an example of a personal task that can be tracked.</field>
            <field name="assigned_to" ref="base.user_demo"/>
            <field name="category_id" ref="category_personal"/>
            <field name="priority">1</field>
            <field name="state">draft</field>
            <field name="date_deadline" eval="(DateTime.today() + timedelta(days=7)).strftime('%Y-%m-%d')"/>
        </record>
        
    </data>
</odoo>