<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Default Categories -->
        <record id="category_work" model="todo.category">
            <field name="name">Work</field>
            <field name="description">Work-related tasks</field>
            <field name="color">2</field>
        </record>
        
        <record id="category_personal" model="todo.category">
            <field name="name">Personal</field>
            <field name="description">Personal tasks</field>
            <field name="color">5</field>
        </record>
        
        <record id="category_project" model="todo.category">
            <field name="name">Project</field>
            <field name="description">Project-related tasks</field>
            <field name="color">8</field>
        </record>
        
        <!-- Default Tags -->
        <record id="tag_urgent" model="todo.tag">
            <field name="name">Urgent</field>
            <field name="color">1</field>
        </record>
        
        <record id="tag_important" model="todo.tag">
            <field name="name">Important</field>
            <field name="color">3</field>
        </record>
        
        <record id="tag_meeting" model="todo.tag">
            <field name="name">Meeting</field>
            <field name="color">4</field>
        </record>
        
        <record id="tag_follow_up" model="todo.tag">
            <field name="name">Follow-up</field>
            <field name="color">6</field>
        </record>
        
        <!-- Automated Action: Check Deadlines -->
        <record id="cron_check_deadlines" model="ir.cron">
            <field name="name">Todo: Check Deadlines</field>
            <field name="model_id" ref="model_todo_task"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_deadlines()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
        
    </data>
</odoo>