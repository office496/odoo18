<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Todo Task Views -->
        <record id="view_todo_task_form" model="ir.ui.view">
            <field name="name">todo.task.form</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <form string="Todo Task">
                    <header>
                        <button name="action_start" string="Start" type="object" 
                                states="draft" class="oe_highlight"/>
                        <button name="action_done" string="Mark Done" type="object" 
                                states="in_progress" class="oe_highlight"/>
                        <button name="action_cancel" string="Cancel" type="object" 
                                states="draft,in_progress"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" 
                                states="done,cancelled"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_assign_to_me" type="object" 
                                    class="oe_stat_button" icon="fa-user">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Assign to Me</span>
                                </div>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Overdue" bg_color="bg-danger" 
                                attrs="{'invisible': [('is_overdue', '=', False)]}"/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="assigned_to"/>
                                <field name="category_id"/>
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </group>
                            <group>
                                <field name="priority" widget="priority"/>
                                <field name="date_deadline"/>
                                <field name="days_to_deadline"/>
                                <field name="is_overdue" invisible="1"/>
                                <field name="progress_percentage" widget="progressbar"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description" widget="html"/>
                            </page>
                            <page string="Details">
                                <group>
                                    <group>
                                        <field name="date_created"/>
                                        <field name="date_completed"/>
                                        <field name="sequence"/>
                                    </group>
                                    <group>
                                        <field name="active"/>
                                        <field name="color"/>
                                    </group>
                                </group>
                                <field name="notes" placeholder="Internal notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        
        <record id="view_todo_task_tree" model="ir.ui.view">
            <field name="name">todo.task.tree</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <tree string="Todo Tasks" decoration-danger="is_overdue" decoration-success="state=='done'">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="assigned_to"/>
                    <field name="category_id"/>
                    <field name="priority" widget="priority"/>
                    <field name="date_deadline"/>
                    <field name="days_to_deadline"/>
                    <field name="state" widget="badge" decoration-info="state=='draft'" 
                           decoration-warning="state=='in_progress'" decoration-success="state=='done'" 
                           decoration-danger="state=='cancelled'"/>
                    <field name="progress_percentage" widget="progressbar"/>
                    <field name="is_overdue" invisible="1"/>
                </tree>
            </field>
        </record>
        
        <record id="view_todo_task_kanban" model="ir.ui.view">
            <field name="name">todo.task.kanban</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="assigned_to"/>
                    <field name="priority"/>
                    <field name="date_deadline"/>
                    <field name="state"/>
                    <field name="is_overdue"/>
                    <field name="color"/>
                    <field name="tag_ids"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click">
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a name="action_start" type="object" class="dropdown-item" t-if="record.state.raw_value == 'draft'">Start</a>
                                        <a name="action_done" type="object" class="dropdown-item" t-if="record.state.raw_value == 'in_progress'">Mark Done</a>
                                        <a name="action_cancel" type="object" class="dropdown-item" t-if="record.state.raw_value in ['draft', 'in_progress']">Cancel</a>
                                        <a name="action_reset_to_draft" type="object" class="dropdown-item" t-if="record.state.raw_value in ['done', 'cancelled']">Reset</a>
                                    </div>
                                </div>
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                        <div class="o_kanban_record_top_right">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <div t-if="record.assigned_to.raw_value">
                                            <i class="fa fa-user"/> <field name="assigned_to"/>
                                        </div>
                                        <div t-if="record.date_deadline.raw_value" t-attf-class="#{record.is_overdue.raw_value ? 'text-danger' : ''}">
                                            <i class="fa fa-calendar"/> <field name="date_deadline"/>
                                        </div>
                                        <div class="mt-2">
                                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <record id="view_todo_task_search" model="ir.ui.view">
            <field name="name">todo.task.search</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <search string="Search Todo Tasks">
                    <field name="name"/>
                    <field name="assigned_to"/>
                    <field name="category_id"/>
                    <field name="description"/>
                    
                    <filter name="my_tasks" string="My Tasks" domain="[('assigned_to', '=', uid)]"/>
                    <filter name="unassigned" string="Unassigned" domain="[('assigned_to', '=', False)]"/>
                    <separator/>
                    <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                    <filter name="due_today" string="Due Today" domain="[('date_deadline', '=', context_today())]"/>
                    <filter name="due_this_week" string="Due This Week" 
                            domain="[('date_deadline', '&gt;=', context_today()), ('date_deadline', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                    <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <filter name="high_priority" string="High Priority" domain="[('priority', 'in', ['2', '3'])]"/>
                    
                    <group expand="0" string="Group By">
                        <filter name="group_assigned_to" string="Assigned To" domain="[]" context="{'group_by': 'assigned_to'}"/>
                        <filter name="group_category" string="Category" domain="[]" context="{'group_by': 'category_id'}"/>
                        <filter name="group_state" string="State" domain="[]" context="{'group_by': 'state'}"/>
                        <filter name="group_priority" string="Priority" domain="[]" context="{'group_by': 'priority'}"/>
                        <filter name="group_deadline" string="Deadline" domain="[]" context="{'group_by': 'date_deadline'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_todo_task" model="ir.actions.act_window">
            <field name="name">Todo Tasks</field>
            <field name="res_model">todo.task</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="context">{'search_default_my_tasks': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first todo task!
                </p>
                <p>
                    Organize your work with todo tasks. You can set priorities,
                    assign deadlines, and track progress.
                </p>
            </field>
        </record>
        
        <record id="action_todo_task_my" model="ir.actions.act_window">
            <field name="name">My Tasks</field>
            <field name="res_model">todo.task</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('assigned_to', '=', uid)]</field>
            <field name="context">{'default_assigned_to': uid}</field>
        </record>
        
        <record id="action_todo_task_overdue" model="ir.actions.act_window">
            <field name="name">Overdue Tasks</field>
            <field name="res_model">todo.task</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('is_overdue', '=', True)]</field>
        </record>
        
    </data>
</odoo>